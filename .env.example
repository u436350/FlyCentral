# Local development API
VITE_API_URL=http://localhost:4001

# Production behavior
# true  -> use in-app mock data when backend network errors occur
# false -> strict live mode (recommended for production)
VITE_ENABLE_DEMO_FALLBACK=true

# true  -> try legacy fallback API URLs when configured URL fails
# false -> use only VITE_API_URL
VITE_ENABLE_API_URL_FAILOVER=true
